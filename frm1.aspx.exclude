                                                     <div class="col-md-11 text-right">
                                             <asp:Button ID="btnreturn" runat="server" Text="Return" CssClass="btn  bg-blue" OnClick="btnreturn_Click" ForeColor="White" />
                                             <asp:Button ID="btnreject" runat="server" Text="Remove" CssClass="btn btn-danger"  OnClick="btnreject_Click" ForeColor="White" /> 
                                             <asp:Button ID="btnapprove" runat="server" Text="Approve" CssClass="btn btn-success" OnClick="btnapprove_Click" ForeColor="White" />    
                                             <asp:Button ID="btnSubmit" runat="server" Text="Submit For Approval" CssClass="btn btn-primary" OnClick="btnSubmit_Click" BackColor="#993399" ForeColor="White"/>  
                                                         <asp:Button ID="btnAssign" runat="server" Text="Submit" CssClass="btn btn-primary" Visible="false" BackColor="#990099" ForeColor="White" />      
            </div>
                                                                            </div>
                                                    </div>
                                                
                                            </asp:Panel>

                                            
                                              </div>
