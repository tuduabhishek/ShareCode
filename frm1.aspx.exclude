                                                <label class="col-md-4 text-primary">
                                                </label>
                                                <div class="col-md-8">
                                                    <asp:Button ID="Button1" runat="server" Text="Add" CssClass="btn btn-primary btn-block " OnClick="Button1_Click"
                                                         UseSubmitBehavior="false" OnClientClick ="this.disabled='true';this.value ='Please wait ...';" />
                                                </div>
                                            </div>
