    Protected Sub gvself_RowDataBound(sender As Object, e As GridViewRowEventArgs)

        Try
            Dim id = CType(e.Row.FindControl("hdfnid"), HiddenField)
            Dim chk = CType(e.Row.FindControl("chkseldsel"), CheckBox)
            Dim perno = CType(e.Row.FindControl("lblpno"), Label)

            Dim comnd As New OracleCommand()
            If perno.Text = "" Then
                comnd.CommandText = " select *  from t_survey_status  where SS_STATUS='SE' and SS_ID='" & id.Value & "'"
            Else
                comnd.CommandText = " select *  from t_survey_status  where SS_STATUS='SE' and ss_pno='" & perno.Text & "'"
            End If

            Dim d = getRecordInDt(comnd, conHrps)

            If d.Rows.Count > 0 Then
                chk.Checked = True
            Else
                chk.Checked = False
            End If


        Catch ex As Exception
            ' MsgBox(ex.ToString())
        End Try

    End Sub

    Public Sub DispGrd(categ As String)
        Try
            Dim pno = Session("USER_ID").ToString()
            Dim cmd As New OracleCommand

            If categ <> "" Then

                cmd.CommandText = " select SS_ID, SS_PNO ,SS_NAME,EMA_EMPL_SGRADE EMA_EMPL_PGRADE,SS_DESG,SS_DEPT,SS_EMAIL,IRC_DESC from tips.t_empl_all , t_survey_status, t_ir_codes where "
                cmd.CommandText += " SS_PNO=ema_perno(+) and IRC_CODE = SS_CATEG and irc_type='360RL' and IRC_VALID_TAG='A' and SS_CATEG ='" & categ & "' "
                cmd.CommandText += " and SS_CRT_BY ='" & pno & "' order by IRC_DESC"
            Else
                cmd.CommandText = " select SS_ID, SS_PNO ,SS_NAME,EMA_EMPL_SGRADE EMA_EMPL_PGRADE,SS_DESG,SS_DEPT,SS_EMAIL,IRC_DESC from tips.t_empl_all , t_survey_status, t_ir_codes where "
                cmd.CommandText += " SS_PNO=ema_perno(+) and IRC_CODE = SS_CATEG and irc_type='360RL' and IRC_VALID_TAG='A'  and SS_CRT_BY ='" & pno & "' and SS_STATUS ='SE' "
                cmd.CommandText += " union  select SS_ID, SS_PNO ,SS_NAME,EMA_EMPL_SGRADE EMA_EMPL_PGRADE,SS_DESG,SS_DEPT,SS_EMAIL,SS_CATEG IRC_DESC from  t_survey_status,tips.t_empl_all where "
                cmd.CommandText += "  ema_perno = SS_PNO and  SS_PNO='" & pno & "'and SS_STATUS ='SE'  "
                cmd.CommandText += " union  select SS_ID, SS_PNO ,SS_NAME,EMA_EMPL_SGRADE EMA_EMPL_PGRADE,SS_DESG,SS_DEPT,SS_EMAIL,SS_CATEG IRC_DESC from t_survey_status,tips.t_empl_all "
                cmd.CommandText += " where  SS_PNO = ema_perno and SS_PNO='" & pno & "'and SS_STATUS ='SE' and SS_CATEG ='Self'  order by IRC_DESC"
            End If

            Dim dt = getRecordInDt(cmd, conHrps)
            If dt.Rows.Count > 0 Then
                GvCateg.DataSource = dt
                GvCateg.DataBind()
                GvCateg.Columns(0).Visible = False
            Else
                GvCateg.DataSource = Nothing
                GvCateg.DataBind()
            End If
            If categ = "PEER" Or categ = "INTSH" Then
                GvCateg.Columns(8).Visible = True
            Else
                GvCateg.Columns(8).Visible = False

            End If
        Catch ex As Exception

        End Try
    End Sub

    Public Sub DispGrd1()
        Try
            Dim pno = Session("USER_ID").ToString()
            Dim cmd As New OracleCommand
            Dim perno = SimpleCrypt(Request.QueryString("pno"))

            cmd.CommandText = " select ss_id, SS_PNO ,SS_NAME,EMA_EMPL_SGRADE EMA_EMPL_PGRADE,SS_DESG,SS_DEPT,SS_EMAIL,IRC_DESC from tips.t_empl_all , t_survey_status, t_ir_codes where "
            cmd.CommandText += " SS_PNO=ema_perno(+) and IRC_CODE = SS_CATEG and irc_type='360RL' and IRC_VALID_TAG='A'  "
            cmd.CommandText += "And SS_APPROVER ='" & pno & "' and SS_TAG='SU' and SS_STATUS ='SE' and SS_ASSES_PNO='" & perno & "'"

            Dim dt = getRecordInDt(cmd, conHrps)
            If dt.Rows.Count > 0 Then
                GvCateg.DataSource = dt
                GvCateg.DataBind()
                GvCateg.Columns(8).Visible = False
            End If
        Catch ex As Exception

        End Try
    End Sub
    Protected Sub lbselect_Click(sender As Object, e As EventArgs)
        Try
            Dim tmp As GridViewRow = CType(sender, LinkButton).Parent.Parent

            Dim pno = CType(tmp.FindControl("lblpno"), Label).Text
            Dim name = CType(tmp.FindControl("lnlname"), Label).Text
            Dim grade = CType(tmp.FindControl("lbllevel"), Label).Text
            Dim desg = CType(tmp.FindControl("lbldesg"), Label).Text
            Dim dept = CType(tmp.FindControl("lbldept"), Label).Text
            Dim email = CType(tmp.FindControl("lblemail"), Label).Text
            Dim sel = CType(tmp.FindControl("lbselect"), LinkButton)

            Dim qry As New OracleCommand()
            qry.CommandText = " select  SS_STATUS  from t_survey_status where SS_PNO ='" & pno & "' and SS_CATEG ='" & ddlrole.SelectedValue & "'"
            Dim dt = getRecordInDt(qry, conHrps)
            If dt.Rows.Count > 0 Then
                If dt.Rows(0)(0).ToString() = "SE" Then
                    ShowGenericMessageModal(CommonConstants.AlertType.warning, "Participants already selected...!")
                Else
                    UpdateStatus(pno, "SE")
                    ShowGenericMessageModal(CommonConstants.AlertType.success, "Selected...!")
                End If

            Else
                SaveData(ddlrole.SelectedValue, pno, name, desg, Replace(dept, "'", "''"), email, "ORG", "SE")
                DispGrd(ddlrole.SelectedValue)

                ShowGenericMessageModal(CommonConstants.AlertType.success, "Selected...!")
                ' sel.Text = "DeSelect"

            End If

        Catch ex As Exception

        End Try
    End Sub
    Protected Sub btnSubmit_Click(sender As Object, e As EventArgs)
        Try
            If ChkValidation() Then
                ShowGenericMessageModal(CommonConstants.AlertType.error, "Please select Minimum no of assessors in each category...!")
                Exit Sub
            End If
            Dim comd As New OracleCommand()
            Dim pno = Session("USER_ID").ToString()
            comd.CommandText = " select EMA_PERS_EXEC_PNO from tips.t_empl_all where ema_perno='" & pno & "'"
            Dim dt = getRecordInDt(comd, conHrps)
            If dt.Rows.Count > 0 Then
                UpdateApprover(dt.Rows(0)("EMA_PERS_EXEC_PNO").ToString, pno)
            End If

            Dim qry As String = String.Empty
            qry = " update t_survey_status set SS_TAG ='SU' , SS_TAG_DT = sysdate where SS_STATUS ='SE' and SS_CRT_BY ='" & pno & "'"
            If conHrps.State = ConnectionState.Closed Then
                conHrps.Open()
            End If

            Dim cmd As New OracleCommand(qry, conHrps)
            cmd.ExecuteNonQuery()
            ShowGenericMessageModal(CommonConstants.AlertType.success, "Submitted for Approval...!")
            btnSubmit.Enabled = True

        Catch ex As Exception

        Finally
            If conHrps.State = ConnectionState.Open Then
                conHrps.Close()
            End If
        End Try
    End Sub

    Public Sub enableControl()

        Try
            Dim pno = Session("USER_ID").ToString()
            Dim cmd As New OracleCommand()
            cmd.CommandText = " select * from t_survey_status where SS_ASSES_PNO ='" & pno & "' and SS_TAG ='SU' "
            Dim d = getRecordInDt(cmd, conHrps)
            If d.Rows.Count <= 0 Then
            Else
                lbview.Enabled = False
                btnAssign.Enabled = False
                btnSubmit.Enabled = False
                Button1.Enabled = False
                lbOrg.Enabled = False
                lbNonOrg.Enabled = False
                GvCateg.Columns(8).Visible = False
            End If
        Catch ex As Exception

        End Try
    End Sub


    Public Function ChKRole(user As String) As Boolean
        Dim role As Boolean = False
        Try
            Dim qry As String = String.Empty

            qry = "select * from t_survey_status  where SS_APPROVER='" & user & "'"
            Dim cod As New OracleCommand()
            cod.CommandText = qry
            Dim dt = getRecordInDt(cod, conHrps)
            If dt.Rows.Count > 0 Then
                role = True
            End If

        Catch ex As Exception

        End Try
        Return role

    End Function
    Public Sub UpdateStatus(id As String, tag As String)
        Try
            Dim query As String = String.Empty
            Dim pno = Session("USER_ID").ToString()
            If id.StartsWith("SR") Then
                query = "update t_survey_status set SS_STATUS ='" & tag & "' where SS_ID='" & id & "' and SS_CRT_BY ='" & pno & "'"
            Else
                query = "update t_survey_status set SS_STATUS ='" & tag & "' where SS_PNO='" & id & "' and SS_CRT_BY ='" & pno & "'"
            End If


            If conHrps.State = ConnectionState.Closed Then
                conHrps.Open()
            End If
            Dim comnd As New OracleCommand(query, conHrps)
            comnd.ExecuteNonQuery()
        Catch ex As Exception
        Finally
            If conHrps.State = ConnectionState.Open Then
                conHrps.Close()
            End If
        End Try
    End Sub

    Public Sub UpdateStatus1(id As String, tag As String)
        Try
            Dim query As String = String.Empty
            Dim pno = Session("USER_ID").ToString()
            query = "update t_survey_status set SS_APP_TAG ='" & tag & "', SS_APP_DT = sysdate ,SS_APP_BY='" & pno & "' where SS_PNO='" & id & "' "
            query += " and SS_APPROVER ='" & pno & "'"
            If conHrps.State = ConnectionState.Closed Then
                conHrps.Open()
            End If
            Dim comnd As New OracleCommand(query, conHrps)
            comnd.ExecuteNonQuery()
        Catch ex As Exception
        Finally
            If conHrps.State = ConnectionState.Open Then
                conHrps.Close()
            End If
        End Try
    End Sub
    Protected Sub btnreturn_Click(sender As Object, e As EventArgs)
        Try
            Dim c As Boolean = False
            For i As Integer = 0 To GvCateg.Rows.Count
                Dim chk = CType(GvCateg.Rows(i).FindControl("chkmgr"), CheckBox)
                Dim pno = CType(GvCateg.Rows(i).FindControl("lblpno"), Label)
                Dim id = CType(GvCateg.Rows(i).FindControl("hdfnid"), HiddenField)

                If chk.Checked = True Then
                    UpdateStatus1(id.Value, "RN")
                    c = True
                Else
                    c = False
                End If
            Next

            If c Then
                ShowGenericMessageModal(CommonConstants.AlertType.success, "Selected person has been Returned...!")
            Else
                ShowGenericMessageModal(CommonConstants.AlertType.success, "Please check at least one person to Return...!")
                Exit Sub
            End If
            DispGrd1()
        Catch ex As Exception

        End Try
    End Sub
