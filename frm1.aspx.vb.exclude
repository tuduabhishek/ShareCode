        End Try
    End Sub
    Protected Sub btnAssign_Click(sender As Object, e As EventArgs) Handles btnAssign.Click
        Try
            For i As Integer = 0 To GvCateg.Rows.Count - 1

                Dim pno As String = String.Empty
                Dim id As String = String.Empty
                Dim name As String = String.Empty
                Dim desg As String = String.Empty
                Dim Org As String = String.Empty
                Dim email As String = String.Empty
                Dim Type As String = String.Empty

                pno = CType(GvCateg.Rows(i).FindControl("lblpno"), Label).Text
                id = CType(GvCateg.Rows(i).FindControl("hdfnid"), HiddenField).Value
                name = CType(GvCateg.Rows(i).FindControl("lnlname"), Label).Text
                desg = CType(GvCateg.Rows(i).FindControl("lbldesg"), Label).Text
                Org = CType(GvCateg.Rows(i).FindControl("lbldept"), Label).Text
                email = CType(GvCateg.Rows(i).FindControl("lblemail"), Label).Text

                If CType(GvCateg.Rows(i).FindControl("chkseldsel"), CheckBox).Checked = True Then

                    UpdateData(id, "SE")
                Else

                    UpdateData(id, "DS")
                End If

            Next

            ShowGenericMessageModal(CommonConstants.AlertType.success, "Operation Done...!")
        Catch ex As Exception
            MsgBox(ex.ToString())
        End Try
    End Sub
