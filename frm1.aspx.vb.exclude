    Public Sub chkApproval()
        Try

            Dim qry As String = String.Empty
            Dim pno = Session("USER_ID").ToString()
            qry = "select * from t_survey_status where ss_crt_by='" & pno & "' and SS_TAG='SU'"
            Dim cod As New OracleCommand()
            cod.CommandText = qry
            Dim dt = getRecordInDt(cod, conHrps)
            If dt.Rows.Count > 0 Then
                gvself.Columns(6).Visible = False
                GvCateg.Columns(8).Visible = False
            End If

        Catch ex As Exception

        End Try
    End Sub

    Public Function ChkValidation() As Boolean
        Dim status As Boolean = False
        Try

            Dim cmdqry As New OracleCommand()
            cmdqry.CommandText = "select IRC_CODE,SUBSTR(IRC_DESC,0,1) minmum, SUBSTR(IRC_DESC,3,1) maximum from t_ir_codes  where irc_type='360VL' and irc_valid_tag='A'"
            Dim dt = getRecordInDt(cmdqry, conHrps)

            If dt.Rows.Count > 0 Then
                For i = 0 To dt.Rows.Count
                    cmdqry = New OracleCommand()
                    cmdqry.CommandText = " select * from t_survey_status where SS_CRT_BY ='" & Session("USER_ID").ToString() & "' "
                    cmdqry.CommandText += " and upper(SS_CATEG) = '" & dt.Rows(i)("IRC_CODE").ToString().ToUpper & "' and SS_STATUS='SE'"
                    Dim dtls = getRecordInDt(cmdqry, conHrps)

                    If dtls.Rows.Count < dt.Rows(i)("minmum") Then
                        status = True
                    End If
                    If dt.Rows(i)("maximum") = "N" Then

                    Else
                        If dtls.Rows.Count > dt.Rows(i)("maximum") Then
                            status = True
                        End If

                    End If

                Next
            End If
        Catch ex As Exception

        End Try
        Return status
    End Function
    Public Sub GetSelected(dt As DataTable)
        Try
            If Request.QueryString("pno") <> Nothing Then

                For o = 0 To dt.Rows.Count - 1
                    Dim strself = New OracleCommand()
                    strself.CommandText = "select * from t_survey_status  where SS_PNO ='" & dt.Rows(o)("ema_perno").ToString() & "'"
                    Dim dt1 = getRecordInDt(strself, conHrps)
                    If dt1.Rows.Count > 0 Then
                    Else
                        SaveData(ddlrole.SelectedValue, dt.Rows(o)("ema_perno").ToString(), dt.Rows(o)("ema_ename").ToString(), dt.Rows(o)("EMA_DESGN_DESC").ToString(), dt.Rows(o)("EMA_DEPT_DESC").ToString(), dt.Rows(o)("EMA_EMAIL_ID").ToString(), "ORG", "SE")
                    End If
                Next
                GvCateg.Columns(8).Visible = False

            End If
        Catch ex As Exception

        End Try
    End Sub
    Protected Sub GvCateg_RowDataBound(sender As Object, e As GridViewRowEventArgs)
        Try
            Dim id = CType(e.Row.FindControl("hdfnid"), HiddenField)
            Dim chk = CType(e.Row.FindControl("chkseldsel"), CheckBox)
            Dim perno = CType(e.Row.FindControl("lblpno"), Label)

            Dim comnd As New OracleCommand()
            If perno.Text = "" Then
                comnd.CommandText = " select *  from t_survey_status  where SS_STATUS='SE' and SS_ID='" & id.Value & "'"
            Else
                comnd.CommandText = " select *  from t_survey_status  where SS_STATUS='SE' and ss_pno='" & perno.Text & "'"
            End If

            Dim d = getRecordInDt(comnd, conHrps)

            If d.Rows.Count > 0 Then
                chk.Checked = True
            Else
                chk.Checked = False
            End If


        Catch ex As Exception
            ' MsgBox(ex.ToString())
        End Try

    End Sub
End Class
