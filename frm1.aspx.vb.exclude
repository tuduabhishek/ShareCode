    Protected Sub Page_Load(ByVal sender As Object, ByVal e As System.EventArgs) Handles Me.Load

        If Not Page.IsPostBack Then
            If Request.QueryString("pno") <> Nothing Then
                hdfnchk.Value = "0"
                btnapprove.Visible = True
                btnreject.Visible = True
                btnreturn.Visible = True
                lbview.Visible = False
                DispGrd1()
                PopDroupdown()

            Else
                Dim msg As String = String.Empty
                msg = ""“Over the next 5-10 years, we aim to be the most valuable and respected steel company globally."
                msg += " The change that we need to focus on is not just one of business processes, but one of cultural change. "
                msg += "In order to bring this cultural change, it is important to focus on design and implement a new PMS process "
                msg += " which enables such behaviours at workplace. Thus, with this in mind it has been decided to design and implement "
                msg += "a 360-degree assessment which will form a part of the new PMS process”""
                Lblmessage.Text = msg
                ScriptManager.RegisterStartupScript(Me.Page, GetType(String), "infomodal", "showModalDiv('#divalert');", True)

                'chkApproval()
                hdfnchk.Value = "1"
                btnapprove.Visible = False
                btnreject.Visible = False
                btnreturn.Visible = False
                btnSubmit.Visible = True
                PopDroupdown()
                DispSelf()

                DispGrd("")
                enableControl()
            End If


        End If

    End Sub
    Public Function SimpleCrypt(ByVal Text As String) As String

        Dim strTempChar As String = "", i As Integer
        For i = 1 To Text.Length
            If Asc(Mid$(Text, i, 1)) < 128 Then
                strTempChar = CType(Asc(Mid$(Text, i, 1)) + 128, String)
            ElseIf Asc(Mid$(Text, i, 1)) > 128 Then
                strTempChar = CType(Asc(Mid$(Text, i, 1)) - 128, String)
            End If
            Mid$(Text, i, 1) = Chr(CType(strTempChar, Integer))
        Next i
        Return Text

    End Function

#Region "GenericMessage"
