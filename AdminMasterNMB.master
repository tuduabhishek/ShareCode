        <script type="text/javascript">
            if (window.history.replaceState) {
                window.history.replaceState(null, null, window.location.href);
            }
            $(function () {
                $(document).keydown(function (e) {
                    return (e.which || e.keyCode) != 116;
                });
            });
        </script>
