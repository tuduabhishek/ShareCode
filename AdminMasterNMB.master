            $('#<%=txt_dor.ClientID%>').datepicker({ format: 'dd-M-yyyy', endDate: '+0d', autoclose: true });
        };--%>
        function ShowApprovePopup() {
            var myModal = new bootstrap.Modal(document.getElementById('staticBackdroppend'));
            myModal.show();
        }
    </script>
