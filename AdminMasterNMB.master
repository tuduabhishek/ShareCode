                                    </div>
                                    <div class="col-sm-4">
                                        <label>Category</label>
                                        <asp:DropDownList runat="server" ID="ddltype" CssClass="form-control" AutoPostBack="true" OnSelectedIndexChanged="ddltype_SelectedIndexChanged">
                                            <asp:ListItem Value="Rp">--Select Option--</asp:ListItem>
                                            <asp:ListItem Value="pno">Enter Pno</asp:ListItem>
                                            <asp:ListItem Value="IL3">Overall IL1-3</asp:ListItem>
                                            <asp:ListItem Value="IL4">Overall IL4-6</asp:ListItem>
                                        </asp:DropDownList>
                                    </div>
                                    <div class="col-sm-4">
                                        <label>Assesee P. No.</label>
                                        <asp:TextBox runat="server" ID="TextBox1" CssClass="form-control" />
                                    </div>
                                </div>
                            </ContentTemplate>
                        </asp:UpdatePanel>
                    </div>
